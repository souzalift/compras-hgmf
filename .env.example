# Copie para .env.local e preencha. Na Vercel: Settings > Environment Variables.

# ── Azure AD ──────────────────────────────────────────────────────────────────
TENANT_ID=
CLIENT_ID=
CLIENT_SECRET=   # opcional se usar ROPC

# ── Credenciais do usuário dono da planilha (ROPC) ────────────────────────────
# Necessário para OneDrive pessoal/corporativo sem permissão de admin.
# Use a conta Microsoft que tem acesso à planilha.
MS_USERNAME=
MS_PASSWORD=

# ── Planilha ──────────────────────────────────────────────────────────────────
WORKBOOK_ID=

# ── Opcional: apenas se a planilha estiver no SharePoint ─────────────────────
# SITE_ID=id-do-site-sharepoint
# DRIVE_ID=id-do-drive-sharepoint
